# LLM (Kimi K2.5 via GMI Serving — OpenAI-compatible)
LLM_API_KEY=your-gmi-serving-api-key
LLM_MODEL=moonshotai/Kimi-K2.5
LLM_BASE_URL=https://api.gmi-serving.com/v1

# HydraDB Memory
HYDRA_OPENCLAW_API_KEY=your-hydradb-api-key

# One (withone.ai) Integrations
ONE_API_KEY=your-one-api-key

# Firebase (uses ADC — run `gcloud auth application-default login` to authenticate)
FIREBASE_PROJECT_ID=mneme-f0a0d

# Server (Express backend — Next.js frontend proxies /api/* here)
PORT=3001
